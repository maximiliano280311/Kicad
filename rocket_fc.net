    )
    (comp (ref "J2")
      (value "SERVO2")
      (description "Servo 2 header 3-pin 2.54mm SIG=GPIO26")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical")
      (sheetpath (names "/") (tstamps "/"))
      (tstamps "00000073")
    )
    (comp (ref "J3")
      (value "SERVO3")
      (description "Servo 3 header 3-pin SIG=GPIO27")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical")
      (sheetpath (names "/") (tstamps "/"))
      (tstamps "00000074")
    )
    (comp (ref "J4")
      (value "SERVO4")
      (description "Servo 4 header 3-pin SIG=GPIO14 verify safe at boot")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical")
      (sheetpath (names "/") (tstamps "/"))
      (tstamps "00000075")
    )
    (comp (ref "J5")
      (value "PYRO_A")
      (description "Pyro channel A screw terminal 2-pos 3.5mm igniter connection")
      (footprint "Connector_Phoenix_MC_HighVoltage:PhoenixContact_MC_1,5_2-ST-3,5_1x02_P3.50mm_Angled")
      (sheetpath (names "/") (tstamps "/"))
      (tstamps "00000076")
    )
    (comp (ref "J6")
      (value "PYRO_B")
      (description "Pyro channel B screw terminal 2-pos 3.5mm")
      (footprint "Connector_Phoenix_MC_HighVoltage:PhoenixContact_MC_1,5_2-ST-3,5_1x02_P3.50mm_Angled")
      (sheetpath (names "/") (tstamps "/"))
      (tstamps "00000077")
    )
    (comp (ref "J7")
      (value "PROG_HEADER")
      (description "UART programming header 4-pin GND 3V3 TX RX use 3.3V adapter ONLY")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical")
      (sheetpath (names "/") (tstamps "/"))
      (tstamps "00000078")
    )
    (comp (ref "J8")
      (value "BATTERY_JST")
      (description "2S LiPo battery connector JST-XH 2-pin")
      (footprint "Connector_JST:JST_XH_B2B-XH-A_1x02_P2.50mm_Vertical")
      (sheetpath (names "/") (tstamps "/"))
      (tstamps "00000079")
    )
  )

  (nets
    ; =====================================================================
    ; NET: GND  - global ground, single plane
    ; =====================================================================
    (net (code "1") (name "GND")
      (node (ref "U1") (pin "1") (pintype "power_in"))
      (node (ref "U1") (pin "15") (pintype "power_in"))
      (node (ref "U1") (pin "38") (pintype "power_in"))
      (node (ref "U2") (pin "GND") (pintype "power_in"))
      (node (ref "U3") (pin "GND") (pintype "power_in"))
      (node (ref "U4") (pin "GND") (pintype "power_in"))
      (node (ref "U5") (pin "GND") (pintype "power_in"))
      (node (ref "U6") (pin "GND") (pintype "power_in"))
      (node (ref "U7") (pin "GND") (pintype "power_in"))
      (node (ref "U8") (pin "GND") (pintype "power_in"))
      (node (ref "Q2") (pin "S") (pintype "passive"))
      (node (ref "Q3") (pin "S") (pintype "passive"))
      (node (ref "Q4") (pin "E") (pintype "passive"))
      (node (ref "SD1") (pin "GND") (pintype "power_in"))
      (node (ref "C1") (pin "2") (pintype "passive"))
      (node (ref "C2") (pin "2") (pintype "passive"))
      (node (ref "C3") (pin "2") (pintype "passive"))
      (node (ref "C4") (pin "2") (pintype "passive"))
      (node (ref "C5") (pin "2") (pintype "passive"))
      (node (ref "C6") (pin "2") (pintype "passive"))
      (node (ref "C7") (pin "2") (pintype "passive"))
      (node (ref "C8") (pin "2") (pintype "passive"))
      (node (ref "C9") (pin "2") (pintype "passive"))
      (node (ref "C10") (pin "2") (pintype "passive"))
      (node (ref "C11") (pin "2") (pintype "passive"))
      (node (ref "C12") (pin "2") (pintype "passive"))
      (node (ref "C13") (pin "2") (pintype "passive"))
      (node (ref "C14") (pin "2") (pintype "passive"))
      (node (ref "C15") (pin "2") (pintype "passive"))
      (node (ref "C23") (pin "2") (pintype "passive"))
      (node (ref "C24") (pin "2") (pintype "passive"))
      (node (ref "C25") (pin "2") (pintype "passive"))
      (node (ref "R7") (pin "2") (pintype "passive"))
      (node (ref "R8") (pin "2") (pintype "passive"))
      (node (ref "R14") (pin "2") (pintype "passive"))
      (node (ref "LED1") (pin "K") (pintype "passive"))
      (node (ref "SW2") (pin "2") (pintype "passive"))
      (node (ref "SW3") (pin "2") (pintype "passive"))
      (node (ref "J1") (pin "3") (pintype "passive"))
      (node (ref "J2") (pin "3") (pintype "passive"))
      (node (ref "J3") (pin "3") (pintype "passive"))
      (node (ref "J4") (pin "3") (pintype "passive"))
      (node (ref "J7") (pin "1") (pintype "passive"))
      (node (ref "J8") (pin "2") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: VBAT_RAW  - direct from battery before arming switch
    ; =====================================================================
    (net (code "2") (name "VBAT_RAW")
      (node (ref "J8") (pin "1") (pintype "passive"))
      (node (ref "SW1") (pin "1") (pintype "passive"))
      (node (ref "Q1") (pin "S") (pintype "passive"))
      (node (ref "R12") (pin "1") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: VBAT_SWITCHED  - after arming switch, to regulator and pyro bus
    ; =====================================================================
    (net (code "3") (name "VBAT_SWITCHED")
      (node (ref "SW1") (pin "2") (pintype "passive"))
      (node (ref "Q1") (pin "G") (pintype "passive"))
      (node (ref "R12") (pin "2") (pintype "passive"))
      (node (ref "R11") (pin "1") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: VBAT_PROTECTED  - after Q1 reverse polarity MOSFET drain
    ; =====================================================================
    (net (code "4") (name "VBAT_PROTECTED")
      (node (ref "Q1") (pin "D") (pintype "passive"))
      (node (ref "U2") (pin "VIN") (pintype "power_in"))
      (node (ref "C1") (pin "1") (pintype "passive"))
      (node (ref "C2") (pin "1") (pintype "passive"))
      (node (ref "R11") (pin "2") (pintype "passive"))
    )

    ; NET: PYRO_BUS_P - armed high current pyro supply rail
    ; Note: connects via arming switch to protect from accidental firing
    (net (code "5") (name "PYRO_BUS_P")
      (node (ref "SW1") (pin "2") (pintype "passive"))
      (node (ref "J5") (pin "2") (pintype "passive"))
      (node (ref "J6") (pin "2") (pintype "passive"))
      (node (ref "R9") (pin "1") (pintype "passive"))
      (node (ref "R10") (pin "1") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: +5V  - MP1584 output, logic 5V
    ; =====================================================================
    (net (code "6") (name "+5V")
      (node (ref "U2") (pin "VOUT") (pintype "power_out"))
      (node (ref "L1") (pin "2") (pintype "passive"))
      (node (ref "C3") (pin "1") (pintype "passive"))
      (node (ref "C4") (pin "1") (pintype "passive"))
      (node (ref "U3") (pin "VIN") (pintype "power_in"))
      (node (ref "C5") (pin "1") (pintype "passive"))
      (node (ref "R13") (pin "1") (pintype "passive"))
    )

    ; NET: MP1584 SW node (inductor switching node)
    (net (code "7") (name "MP1584_SW")
      (node (ref "U2") (pin "SW") (pintype "passive"))
      (node (ref "L1") (pin "1") (pintype "passive"))
    )

    ; NET: MP1584 feedback
    (net (code "8") (name "MP1584_FB")
      (node (ref "U2") (pin "FB") (pintype "input"))
      (node (ref "R13") (pin "2") (pintype "passive"))
      (node (ref "R14") (pin "1") (pintype "passive"))
    )

    ; NET: MP1584 EN
    (net (code "9") (name "MP1584_EN")
      (node (ref "U2") (pin "EN") (pintype "input"))
      (node (ref "R11") (pin "2") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: +5V_SERVO  - dedicated servo power rail from MP1584
    ; =====================================================================
    (net (code "10") (name "+5V_SERVO")
      (node (ref "C24") (pin "1") (pintype "passive"))
      (node (ref "C25") (pin "1") (pintype "passive"))
      (node (ref "J1") (pin "2") (pintype "passive"))
      (node (ref "J2") (pin "2") (pintype "passive"))
      (node (ref "J3") (pin "2") (pintype "passive"))
      (node (ref "J4") (pin "2") (pintype "passive"))
    )
    ; Note: +5V_SERVO connected to +5V rail at PCB power plane level
    ; Separate net label used to allow designer to add LC filter if needed

    ; =====================================================================
    ; NET: +3.3V  - AMS1117 output, ESP32 and all sensor VCC
    ; =====================================================================
    (net (code "11") (name "+3.3V")
      (node (ref "U3") (pin "VOUT") (pintype "power_out"))
      (node (ref "C6") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "2") (pintype "power_in"))
      (node (ref "C7") (pin "1") (pintype "passive"))
      (node (ref "C8") (pin "1") (pintype "passive"))
      (node (ref "R3") (pin "1") (pintype "passive"))
      (node (ref "R4") (pin "1") (pintype "passive"))
      (node (ref "R1") (pin "1") (pintype "passive"))
      (node (ref "R2") (pin "1") (pintype "passive"))
      (node (ref "U4") (pin "VCC") (pintype "power_in"))
      (node (ref "C9") (pin "1") (pintype "passive"))
      (node (ref "U5") (pin "VDD") (pintype "power_in"))
      (node (ref "U5") (pin "VDDIO") (pintype "power_in"))
      (node (ref "C10") (pin "1") (pintype "passive"))
      (node (ref "U6") (pin "VDD") (pintype "power_in"))
      (node (ref "C11") (pin "1") (pintype "passive"))
      (node (ref "U7") (pin "VCC") (pintype "power_in"))
      (node (ref "C12") (pin "1") (pintype "passive"))
      (node (ref "C13") (pin "1") (pintype "passive"))
      (node (ref "SD1") (pin "VCC") (pintype "power_in"))
      (node (ref "C14") (pin "1") (pintype "passive"))
      (node (ref "U8") (pin "VCC") (pintype "power_in"))
      (node (ref "C15") (pin "1") (pintype "passive"))
      (node (ref "R21") (pin "1") (pintype "passive"))
      (node (ref "R22") (pin "1") (pintype "passive"))
      (node (ref "LED1") (pin "A") (pintype "passive"))
      (node (ref "J7") (pin "2") (pintype "passive"))
      (node (ref "D1") (pin "K") (pintype "passive"))
      (node (ref "BZ1") (pin "1") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: ESP32_EN  - reset with RC
    ; =====================================================================
    (net (code "12") (name "ESP32_EN")
      (node (ref "U1") (pin "3") (pintype "input"))
      (node (ref "R3") (pin "2") (pintype "passive"))
      (node (ref "C23") (pin "1") (pintype "passive"))
      (node (ref "SW2") (pin "1") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: GPIO0  - boot mode
    ; =====================================================================
    (net (code "13") (name "GPIO0")
      (node (ref "U1") (pin "25") (pintype "bidirectional"))
      (node (ref "R4") (pin "2") (pintype "passive"))
      (node (ref "SW3") (pin "1") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: I2C_SDA
    ; =====================================================================
    (net (code "14") (name "I2C_SDA")
      (node (ref "U1") (pin "33") (pintype "bidirectional"))
      (node (ref "R1") (pin "2") (pintype "passive"))
      (node (ref "U4") (pin "SDA") (pintype "bidirectional"))
      (node (ref "U5") (pin "SDI") (pintype "bidirectional"))
      (node (ref "U6") (pin "SDA") (pintype "bidirectional"))
    )

    ; =====================================================================
    ; NET: I2C_SCL
    ; =====================================================================
    (net (code "15") (name "I2C_SCL")
      (node (ref "U1") (pin "36") (pintype "bidirectional"))
      (node (ref "R2") (pin "2") (pintype "passive"))
      (node (ref "U4") (pin "SCL") (pintype "input"))
      (node (ref "U5") (pin "SCK") (pintype "input"))
      (node (ref "U6") (pin "SCL") (pintype "input"))
    )

    ; NET: MPU6050 address select
    (net (code "16") (name "MPU6050_AD0")
      (node (ref "U4") (pin "AD0") (pintype "input"))
    )
    ; AD0 pulled to GND via 0R or direct short for address 0x68

    ; NET: MPU6050 INT to GPIO34 (input-only pin)
    (net (code "17") (name "MPU6050_INT")
      (node (ref "U4") (pin "INT") (pintype "output"))
      (node (ref "U1") (pin "6") (pintype "bidirectional"))
    )

    ; NET: BMP280 CSB tied HIGH for I2C mode
    (net (code "18") (name "BMP280_CSB")
      (node (ref "U5") (pin "CSB") (pintype "input"))
    )
    ; CSB connected to +3.3V - selects I2C mode

    ; NET: BMP280 SDO tied LOW for addr 0x76
    (net (code "19") (name "BMP280_SDO")
      (node (ref "U5") (pin "SDO") (pintype "input"))
    )
    ; SDO connected to GND - sets I2C address 0x76

    ; =====================================================================
    ; NET: SPI_SCK
    ; =====================================================================
    (net (code "20") (name "SPI_SCK")
      (node (ref "U1") (pin "30") (pintype "bidirectional"))
      (node (ref "R19") (pin "1") (pintype "passive"))
    )
    (net (code "21") (name "SPI_SCK_DAMP")
      (node (ref "R19") (pin "2") (pintype "passive"))
      (node (ref "U7") (pin "SCK") (pintype "input"))
      (node (ref "SD1") (pin "CLK") (pintype "input"))
    )

    ; =====================================================================
    ; NET: SPI_MOSI
    ; =====================================================================
    (net (code "22") (name "SPI_MOSI")
      (node (ref "U1") (pin "37") (pintype "bidirectional"))
      (node (ref "R20") (pin "1") (pintype "passive"))
    )
    (net (code "23") (name "SPI_MOSI_DAMP")
      (node (ref "R20") (pin "2") (pintype "passive"))
      (node (ref "U7") (pin "MOSI") (pintype "input"))
      (node (ref "SD1") (pin "MOSI") (pintype "input"))
    )

    ; =====================================================================
    ; NET: SPI_MISO  - shared, no damping needed on input
    ; =====================================================================
    (net (code "24") (name "SPI_MISO")
      (node (ref "U1") (pin "31") (pintype "bidirectional"))
      (node (ref "U7") (pin "MISO") (pintype "output"))
      (node (ref "SD1") (pin "MISO") (pintype "output"))
    )

    ; =====================================================================
    ; NET: LORA_CS  - GPIO5, must be HIGH at boot (has internal pull-up)
    ; =====================================================================
    (net (code "25") (name "LORA_CS")
      (node (ref "U1") (pin "29") (pintype "bidirectional"))
      (node (ref "U7") (pin "NSS") (pintype "input"))
      (node (ref "R22") (pin "2") (pintype "passive"))
    )

    ; NET: LORA_DIO0 interrupt to GPIO4
    (net (code "26") (name "LORA_DIO0")
      (node (ref "U7") (pin "DIO0") (pintype "output"))
      (node (ref "U1") (pin "26") (pintype "bidirectional"))
    )

    ; NET: LORA_RST to GPIO2
    (net (code "27") (name "LORA_RST")
      (node (ref "U7") (pin "RESET") (pintype "input"))
      (node (ref "U1") (pin "24") (pintype "bidirectional"))
    )

    ; =====================================================================
    ; NET: SD_CS  - GPIO15, MUST be HIGH at boot - R21 100k pull-up
    ; =====================================================================
    (net (code "28") (name "SD_CS")
      (node (ref "U1") (pin "23") (pintype "bidirectional"))
      (node (ref "SD1") (pin "CS") (pintype "input"))
      (node (ref "R21") (pin "2") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: GPS UART
    ; =====================================================================
    (net (code "29") (name "GPS_TX_TO_ESP")
      (node (ref "U8") (pin "TXD") (pintype "output"))
      (node (ref "U1") (pin "27") (pintype "bidirectional"))
    )
    (net (code "30") (name "GPS_RX_FROM_ESP")
      (node (ref "U8") (pin "RXD") (pintype "input"))
      (node (ref "U1") (pin "28") (pintype "bidirectional"))
    )

    ; =====================================================================
    ; NET: SERVO PWM signals
    ; =====================================================================
    (net (code "31") (name "SERVO1_SIG")
      (node (ref "U1") (pin "10") (pintype "bidirectional"))
      (node (ref "J1") (pin "1") (pintype "passive"))
    )
    (net (code "32") (name "SERVO2_SIG")
      (node (ref "U1") (pin "11") (pintype "bidirectional"))
      (node (ref "J2") (pin "1") (pintype "passive"))
    )
    (net (code "33") (name "SERVO3_SIG")
      (node (ref "U1") (pin "12") (pintype "bidirectional"))
      (node (ref "J3") (pin "1") (pintype "passive"))
    )
    (net (code "34") (name "SERVO4_SIG")
      (node (ref "U1") (pin "13") (pintype "bidirectional"))
      (node (ref "J4") (pin "1") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: PYRO CHANNEL A
    ; =====================================================================
    (net (code "35") (name "PYRO_A_GATE_IN")
      (node (ref "U1") (pin "8") (pintype "bidirectional"))
      (node (ref "R5") (pin "1") (pintype "passive"))
    )
    (net (code "36") (name "PYRO_A_GATE")
      (node (ref "R5") (pin "2") (pintype "passive"))
      (node (ref "Q2") (pin "G") (pintype "input"))
      (node (ref "R7") (pin "1") (pintype "passive"))
    )
    (net (code "37") (name "PYRO_A_DRAIN")
      (node (ref "Q2") (pin "D") (pintype "passive"))
      (node (ref "J5") (pin "1") (pintype "passive"))
      (node (ref "R9") (pin "2") (pintype "passive"))
      (node (ref "LED4") (pin "K") (pintype "passive"))
    )
    (net (code "38") (name "CONT_A_LED_A")
      (node (ref "R9") (pin "2") (pintype "passive"))
      (node (ref "LED4") (pin "A") (pintype "passive"))
    )
    ; Note: continuity current flows PYRO_BUS_P -> R9 -> LED4 -> PYRO_A_DRAIN -> Q2_D
    ; Q2 stays OFF when disarmed, ~1.3mA through igniter confirms continuity

    ; =====================================================================
    ; NET: PYRO CHANNEL B
    ; =====================================================================
    (net (code "39") (name "PYRO_B_GATE_IN")
      (node (ref "U1") (pin "9") (pintype "bidirectional"))
      (node (ref "R6") (pin "1") (pintype "passive"))
    )
    (net (code "40") (name "PYRO_B_GATE")
      (node (ref "R6") (pin "2") (pintype "passive"))
      (node (ref "Q3") (pin "G") (pintype "input"))
      (node (ref "R8") (pin "1") (pintype "passive"))
    )
    (net (code "41") (name "PYRO_B_DRAIN")
      (node (ref "Q3") (pin "D") (pintype "passive"))
      (node (ref "J6") (pin "1") (pintype "passive"))
      (node (ref "LED5") (pin "K") (pintype "passive"))
    )
    (net (code "42") (name "CONT_B")
      (node (ref "R10") (pin "2") (pintype "passive"))
      (node (ref "LED5") (pin "A") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: BUZZER
    ; =====================================================================
    (net (code "43") (name "BUZZER_CTRL")
      (node (ref "U1") (pin "16") (pintype "bidirectional"))
      (node (ref "R18") (pin "1") (pintype "passive"))
    )
    (net (code "44") (name "Q4_BASE")
      (node (ref "R18") (pin "2") (pintype "passive"))
      (node (ref "Q4") (pin "B") (pintype "input"))
    )
    (net (code "45") (name "BUZZER_DRIVE")
      (node (ref "Q4") (pin "C") (pintype "passive"))
      (node (ref "BZ1") (pin "2") (pintype "passive"))
      (node (ref "D1") (pin "A") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: STATUS LEDs
    ; =====================================================================
    (net (code "46") (name "LED_GPS_DRV")
      (node (ref "U1") (pin "24") (pintype "bidirectional"))
      (node (ref "R16") (pin "1") (pintype "passive"))
    )
    ; Note: GPIO2 shared with LoRa RESET - firmware must manage
    ; LoRa reset is brief; LED is secondary function

    (net (code "47") (name "LED_GPS_K")
      (node (ref "R16") (pin "2") (pintype "passive"))
      (node (ref "LED2") (pin "A") (pintype "passive"))
    )
    (net (code "48") (name "LED2_K")
      (node (ref "LED2") (pin "K") (pintype "passive"))
    )
    ; LED2 K to GND

    (net (code "49") (name "LED_ARM_DRV")
      (node (ref "U1") (pin "14") (pintype "bidirectional"))
      (node (ref "R17") (pin "1") (pintype "passive"))
    )
    (net (code "50") (name "LED_ARM_K")
      (node (ref "R17") (pin "2") (pintype "passive"))
      (node (ref "LED3") (pin "A") (pintype "passive"))
    )
    (net (code "51") (name "LED3_K")
      (node (ref "LED3") (pin "K") (pintype "passive"))
    )

    (net (code "52") (name "LED1_ANODE")
      (node (ref "R15") (pin "2") (pintype "passive"))
      (node (ref "LED1") (pin "A") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: PROGRAMMING HEADER
    ; =====================================================================
    (net (code "53") (name "UART0_TX")
      (node (ref "U1") (pin "35") (pintype "output"))
      (node (ref "J7") (pin "3") (pintype "passive"))
    )
    (net (code "54") (name "UART0_RX")
      (node (ref "U1") (pin "34") (pintype "input"))
      (node (ref "J7") (pin "4") (pintype "passive"))
    )

    ; =====================================================================
    ; NET: GPIO35 ADC battery voltage monitor
    ; =====================================================================
    (net (code "55") (name "VBAT_ADC")
      (node (ref "U1") (pin "7") (pintype "bidirectional"))
    )
    ; Connect via resistor divider from VBAT_PROTECTED to measure battery
    ; R_top=100k R_bot=33k gives Vadc = Vbat * 0.248 -> max 8.4V*0.248=2.08V safe for ADC

    ; =====================================================================
    ; NET: GPIO36 LoRa DIO1 (optional)
    ; =====================================================================
    (net (code "56") (name "LORA_DIO1")
      (node (ref "U1") (pin "4") (pintype "bidirectional"))
      (node (ref "U7") (pin "DIO1") (pintype "output"))
    )

    ; =====================================================================
    ; NET: GPS TIMEPULSE to GPIO39 (optional 1PPS)
    ; =====================================================================
    (net (code "57") (name "GPS_TIMEPULSE")
      (node (ref "U8") (pin "TIMEPULSE") (pintype "output"))
      (node (ref "U1") (pin "5") (pintype "bidirectional"))
    )

  )
)
